{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hatena-abstract",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-26",
  "triggers": {
    "crons": ["0 */1 * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hatena-abstract-db",
      "database_id": "",
      "migrations_dir": "migrations"
    }
  ]
}
