# Google Generative AI API Key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# Hatena Bookmark API OAuth credentials
HATENA_CONSUMER_KEY=your_hatena_consumer_key
HATENA_CONSUMER_SECRET=your_hatena_consumer_secret
HATENA_ACCESS_TOKEN=your_hatena_access_token
HATENA_ACCESS_TOKEN_SECRET=your_hatena_access_token_secret

# Nostr private key (hex format)
NOSTR_PRIVATE_KEY=your_nostr_private_key_hex